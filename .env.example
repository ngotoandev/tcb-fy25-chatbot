# Copy to .env — used by docker compose. Only needed for real LLM answers.

# LLM provider: bedrock (default, AWS) | anthropic | openai.
LLM_PROVIDER=bedrock

# --- bedrock provider (LLM_PROVIDER=bedrock) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- direct-vendor providers (retrieval falls back to BM25-only; no embeddings) ---
# Set LLM_PROVIDER=anthropic and provide this to use Claude via the Anthropic API:
ANTHROPIC_API_KEY=
# ...or LLM_PROVIDER=openai and provide this to use GPT:
OPENAI_API_KEY=

# Set true to run the UI with zero credentials (canned answers):
MOCK_LLM=false
